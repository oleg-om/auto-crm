{
    "name": "autodom-crm",
    "version": "0.0.3",
    "description": "Autodom CRM",
    "main": "index.js",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "docker-start-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" up",
        "docker-stop-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" down",
        "dev": "yarn run watch:server & yarn run watch:client ",
        "watch:client": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --mode development --config ./webpack.development.config.js",
        "dev:server": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack  --watch --config webpack.development.config.js",
        "start:dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --mode development --config ./webpack.development.config.js --open",
        "start": "cross-env NODE_ENV=production && node start.js",
        "clean": "rimraf dist",
        "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider sh -c \"npm run clean && webpack --config webpack.production.config.js --progress --profile --colors\"",
        "lint": "eslint ./client/**/**.js ./server/**/**.js ",
        "prettier": "prettier ./client/**/**.js ./server/**/**.js --write ",
        "reinstall": "git pull && npm run build && pm2 restart all",
        "lint:server": "eslint ./server/**/**.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "coverage": "jest --coverage",
        "next:build": "next",
        "watch:server": "nodemon --legacy-watch start.js --watch server --exec \"npm run lint:server  --scripts-prepend-node-path && node\"",
        "build:prod": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.production.config.js --progress --profile --colors",
        "build:ssr": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.ssr.config.js --progress --profile --colors",
        "heroku-postbuild": "yarn run build:prod",
        "storybook": "start-storybook -p 6006",
        "build-storybook": "build-storybook",
        "find-unused": "npx dead-exports --e=./client"
    },
    "author": "",
    "license": "MIT",
    "jest": {
        "setupFiles": [
            "<rootDir>/config/jest/shim.js"
        ],
        "collectCoverageFrom": [
            "app/**/*.{js,jsx,ts,tsx}"
        ],
        "moduleNameMapper": {
            "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/config/jest/assetsTransformer.js",
            "\\.(css|less)$": "<rootDir>/config/jest/assetsTransformer.js"
        },
        "testMatch": [
            "**/?(*.)(spec|test).js?(x)"
        ],
        "transform": {
            "\\.js$": "babel-jest"
        }
    },
