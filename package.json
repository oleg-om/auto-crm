{
    "name": "autodom-crm",
    "version": "0.0.3",
    "description": "Autodom CRM",
    "main": "index.js",
    "scripts": {
        "docker-start-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" up",
        "docker-stop-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" down",
        "dev": "yarn run watch:server & yarn run watch:client ",
        "watch:client": "webpack-dev-server --mode development --config ./webpack.development.config.js",
        "dev:server": "webpack  --watch --config webpack.development.config.js",
        "start:dev": "webpack-dev-server --mode development --config ./webpack.development.config.js --open",
        "start": "cross-env NODE_ENV=production && node start.js",
        "clean": "rimraf dist",
        "build": "cross-env npm run clean && webpack --config webpack.production.config.js --progress",
        "lint": "eslint ./client/**/**.js ./server/**/**.js ",
        "prettier": "prettier ./client/**/**.js ./server/**/**.js --write ",
        "reinstall": "git pull && npm run build && pm2 restart all",
        "lint:server": "eslint ./server/**/**.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "coverage": "jest --coverage",
        "next:build": "next",
        "watch:server": "nodemon --legacy-watch start.js --watch server --exec \"npm run lint:server  --scripts-prepend-node-path && node\"",
        "build:prod": "cross-env NODE_ENV=production webpack --config webpack.production.config.js --progress",
        "build:ssr": "cross-env NODE_ENV=production webpack --config webpack.ssr.config.js --progress",
        "heroku-postbuild": "yarn run build:prod",
        "storybook": "start-storybook -p 6006",
        "build-storybook": "build-storybook",
        "find-unused": "npx dead-exports --e=./client"
    },
    "author": "",
    "license": "MIT",
    "jest": {
        "setupFiles": [
            "<rootDir>/config/jest/shim.js"
        ],
        "collectCoverageFrom": [
            "app/**/*.{js,jsx,ts,tsx}"
        ],
        "moduleNameMapper": {
            "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/config/jest/assetsTransformer.js",
            "\\.(css|less)$": "<rootDir>/config/jest/assetsTransformer.js"
        },
        "testMatch": [
            "**/?(*.)(spec|test).js?(x)"
        ],
        "transform": {
            "\\.js$": "babel-jest"
        }
    },
    "dependencies": {
        "@babel/cli": "^7.25.9",
        "@babel/core": "^7.26.0",
        "@babel/eslint-parser": "^7.25.9",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-decorators": "^7.25.9",
        "@babel/plugin-proposal-export-default-from": "^7.25.9",
        "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
        "@babel/plugin-proposal-function-sent": "^7.25.9",
        "@babel/plugin-proposal-json-strings": "^7.18.6",
        "@babel/plugin-proposal-numeric-separator": "^7.18.6",
        "@babel/plugin-proposal-throw-expressions": "^7.25.9",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-syntax-import-meta": "^7.10.4",
        "@babel/plugin-transform-runtime": "^7.25.9",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-flow": "^7.25.9",
        "@babel/preset-react": "^7.25.9",
        "@babel/preset-typescript": "^7.26.0",
        "@babel/register": "^7.25.9",
        "@babel/runtime": "^7.26.0",
        "axios": "^1.7.9",
        "babel-core": "7.0.0-bridge.0",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.2.1",
        "babel-plugin-css-modules-transform": "^1.6.2",
        "bcrypt": "^5.1.1",
        "body-parser": "^1.20.3",
        "classnames": "^2.5.1",
        "connected-react-router": "^6.9.3",
        "cookie-parser": "^1.4.7",
        "core-js": "^3.39.0",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "dayjs": "^1.11.13",
        "dead-exports": "^1.0.13",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "file-saver": "^2.0.5",
        "fix-date": "^1.1.6",
        "history": "^4.10.1",
        "http-proxy-middleware": "^3.0.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.3",
        "mongoose-sequence": "^6.0.1",
        "node-fetch": "^2.7.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "prop-types": "^15.8.1",
        "react": "^18.3.1",
        "react-calendar": "^5.1.0",
        "react-dom": "^18.3.1",
        "react-helmet": "^6.1.0",
        "react-icons": "^5.5.0",
        "react-number-format": "^5.4.2",
        "react-redux": "^9.2.0",
        "react-router": "^5.3.4",
        "react-router-dom": "^5.3.4",
        "react-to-print": "^3.3.0",
        "react-toastify": "^10.0.6",
        "react-uuid": "^2.0.0",
        "redux": "^5.0.1",
        "redux-devtools-extension": "^2.13.9",
        "redux-first-history": "^5.2.0",
        "redux-thunk": "^3.1.0",
        "socket.io": "^4.8.1",
        "socket.io-client": "^4.8.1",
        "universal-cookie": "^7.2.2",
        "uuid": "^11.0.3",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
        "@storybook/addon-actions": "^8.5.0",
        "@storybook/addon-essentials": "^8.5.0",
        "@storybook/addon-links": "^8.5.0",
        "@storybook/cli": "^8.5.0",
        "@storybook/react": "^8.5.0",
        "@storybook/react-webpack5": "^8.5.0",
        "@testing-library/react": "^16.1.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "autoprefixer": "^10.4.20",
        "copy-webpack-plugin": "^12.0.2",
        "cron": "^3.2.0",
        "css-loader": "^7.1.2",
        "cssnano": "^7.0.6",
        "eslint": "^8.57.1",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-react": "^7.37.2",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-webpack-plugin": "^4.2.0",
        "file-loader": "^6.2.0",
        "git-revision-webpack-plugin": "^5.0.0",
        "glob": "^11.0.0",
        "html-webpack-plugin": "^5.6.3",
        "husky": "^9.1.7",
        "image-webpack-loader": "^8.1.0",
        "jest": "^29.7.0",
        "jest-cli": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lodash": "^4.17.21",
        "mini-css-extract-plugin": "^2.9.2",
        "nodemailer": "^6.9.16",
        "nodemon": "^3.1.9",
        "postcss": "^8.4.49",
        "postcss-import": "^16.1.0",
        "postcss-loader": "^8.1.1",
        "postcss-preset-env": "^10.1.3",
        "prettier": "^3.4.2",
        "react-refresh": "^0.14.2",
        "regenerator-runtime": "^0.14.1",
        "rimraf": "^6.0.1",
        "sass": "^1.83.0",
        "sass-loader": "^16.0.3",
        "style-loader": "^4.0.0",
        "tailwindcss": "^3.4.17",
        "terser-webpack-plugin": "^5.3.11",
        "url-loader": "^4.1.1",
        "webpack": "^5.97.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.2.0",
        "zip-lib": "^1.0.4"
    },
    "nodemonConfig": {
        "ignore": [
            "*.hot-update.json"
        ]
    }
}
