{
    "name": "autodom-crm",
    "version": "0.0.3",
    "description": "Autodom CRM",
    "main": "index.js",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "docker-start-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" up",
        "docker-stop-dev": "docker-compose -f \"docker\\DEV.docker-compose.yml\" down",
        "dev": "yarn run watch:server & yarn run watch:client ",
        "watch:client": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --mode development --config ./webpack.development.config.js",
        "dev:server": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack  --watch --config webpack.development.config.js",
        "start:dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --mode development --config ./webpack.development.config.js --open",
        "start": "cross-env NODE_ENV=production && node start.js",
        "clean": "rimraf dist",
        "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider sh -c \"npm run clean && webpack --config webpack.production.config.js --progress --profile --colors\"",
        "lint": "eslint \"./client/**/*.{js,jsx,ts,tsx}\" \"./server/**/*.{js,jsx,ts,tsx}\"",
        "prettier": "prettier \"./client/**/*.{js,jsx,ts,tsx}\" \"./server/**/*.{js,jsx,ts,tsx}\" --write ",
        "typecheck": "tsc --noEmit",
        "reinstall": "git pull && npm run build && pm2 restart all",
        "lint:server": "eslint \"./server/**/*.{js,jsx,ts,tsx}\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "coverage": "jest --coverage",
        "next:build": "next",
        "watch:server": "nodemon --legacy-watch start.js --watch server --exec \"npm run lint:server  --scripts-prepend-node-path && node\"",
        "build:prod": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.production.config.js --progress --profile --colors",
        "build:ssr": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.ssr.config.js --progress --profile --colors",
        "heroku-postbuild": "yarn run build:prod",
        "find-unused": "npx dead-exports --e=./client"
    },
    "author": "",
    "license": "MIT",
    "jest": {
        "setupFiles": [
            "<rootDir>/config/jest/shim.js"
        ],
        "collectCoverageFrom": [
            "app/**/*.{js,jsx,ts,tsx}"
        ],
        "moduleNameMapper": {
            "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/config/jest/assetsTransformer.js",
            "\\.(css|less)$": "<rootDir>/config/jest/assetsTransformer.js"
        },
        "testMatch": [
            "**/?(*.)+(spec|test).[jt]s?(x)"
        ],
        "transform": {
            "\\.[jt]sx?$": "babel-jest"
        }
    },
    "dependencies": {
        "@babel/core": "^7.26.0",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-decorators": "^7.25.0",
        "@babel/plugin-proposal-export-default-from": "^7.25.0",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-transform-runtime": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-react": "^7.26.0",
        "@babel/preset-typescript": "^7.26.0",
        "@babel/register": "^7.26.0",
        "@babel/runtime": "^7.26.0",
        "axios": "1.15.2",
        "babel-core": "7.0.0-bridge.0",
        "babel-jest": "^26.6.3",
        "babel-loader": "^8.4.1",
        "babel-plugin-css-modules-transform": "^1.6.2",
        "babel-plugin-emotion": "^10.0.33",
        "bcrypt-nodejs": "^0.0.3",
        "body-parser": "^1.20.3",
        "classnames": "^2.2.6",
        "connected-react-router": "^6.8.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^7.0.2",
        "dayjs": "^1.11.13",
        "dead-exports": "^1.0.13",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "file-saver": "^2.0.5",
        "fix-date": "^1.1.6",
        "history": "^4.10.1",
        "http-proxy-middleware": "^2.0.9",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^5.13.23",
        "mongoose-sequence": "^5.3.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "prop-types": "^15.7.2",
        "react": "^18.3.1",
        "react-calendar": "^3.2.1",
        "react-dom": "^18.3.1",
        "react-icons": "^5.5.0",
        "react-number-format": "^4.4.1",
        "react-redux": "^7.2.1",
        "react-refresh": "^0.9.0",
        "react-router-dom": "^5.2.0",
        "react-to-print": "^2.12.0",
        "react-toastify": "^6.1.0",
        "react-uuid": "^1.0.2",
        "redux": "^4.0.5",
        "redux-devtools-extension": "^2.13.8",
        "redux-thunk": "^2.3.0",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "string-replace-webpack-plugin": "^0.1.3",
        "universal-cookie": "^4.0.4",
        "uuid": "^11.1.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.26.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.4.3",
        "@testing-library/react": "^14.2.1",
        "@types/node": "^22.10.5",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "autoprefixer": "^9.8.6",
        "copy-webpack-plugin": "^6.4.1",
        "css-loader": "4.2.2",
        "cssnano": "^4.1.10",
        "eslint": "^8.57.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-webpack-plugin": "^2.7.0",
        "file-loader": "6.1.0",
        "git-revision-webpack-plugin": "^3.0.6",
        "image-webpack-loader": "^6.0.0",
        "jest": "^26.6.3",
        "jest-cli": "^26.6.3",
        "mini-css-extract-plugin": "^0.11.0",
        "nodemon": "^2.0.22",
        "optimize-css-assets-webpack-plugin": "^5.0.4",
        "postcss-import": "^12.0.1",
        "postcss-preset-env": "^6.7.0",
        "prettier": "^2.8.8",
        "raw-loader": "^4.0.1",
        "rimraf": "3.0.2",
        "sass": "^1.83.0",
        "sass-loader": "10.0.2",
        "style-loader": "1.2.1",
        "tailwindcss": "^1.8.3",
        "terser-webpack-plugin": "^4.1.0",
        "typescript": "^5.7.3",
        "webpack": "^4.47.0",
        "webpack-cli": "^3.3.12",
        "webpack-dev-server": "^3.11.3"
    },
    "resolutions": {
        "semver": "^6.3.1",
        "ws": "^6.2.3",
        "node-forge": "^1.4.0"
    },
    "nodemonConfig": {
        "ignore": [
            "*.hot-update.json"
        ]
    }
}
